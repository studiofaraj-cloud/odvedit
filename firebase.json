{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs20",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        ".env",
        ".env.*",
        "*.local.js",
        "test-webhook.js",
        "test_webhook_payload.json",
        "env.example",
        "firestore-rules-example.txt",
        "migrations"
      ]
    }
  ],
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/stripeWebhook",
        "function": "stripeWebhook"
      }
    ]
  }
}
